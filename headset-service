:root {
  --bg:        #0f0f0f;
  --surface:   #1a1a1a;
  --surface2:  #222222;
  --border:    #2e2e2e;
  --accent:    #c0392b;   /* Rover Nightfire Red */
  --accent2:   #e74c3c;
  --text:      #e8e8e8;
  --muted:     #888;
  --mono:      'IBM Plex Mono', monospace;
  --sans:      'IBM Plex Sans', sans-serif;
}

body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--sans);
  font-size: 15px;
  line-height: 1.7;
  min-height: 100vh;
}

/* ── HEADER ── */
header {
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  padding: 0 2rem;
}
.header-inner {
  max-width: 900px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.2rem 0;
  gap: 1rem;
}
.brand {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.brand-title {
  font-family: var(--mono);
  font-weight: 600;
  font-size: 1.1rem;
  letter-spacing: 0.08em;
  color: var(--text);
}
.brand-sub {
  font-family: var(--mono);
  font-size: 0.72rem;
  color: var(--muted);
  letter-spacing: 0.05em;
}
.back-link {
  font-family: var(--mono);
  font-size: 0.78rem;
  color: var(--muted);
  text-decoration: none;
  border: 1px solid var(--border);
  padding: 0.4rem 0.9rem;
  border-radius: 4px;
  transition: color 0.2s, border-color 0.2s;
  white-space: nowrap;
}
.back-link:hover { color: var(--text); border-color: var(--muted); }

/* ── NAV TABS (decorative, matching site style) ── */
nav {
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  padding: 0 2rem;
}
.nav-inner {
  max-width: 900px;
  margin: 0 auto;
  display: flex;
  gap: 0;
  overflow-x: auto;
}
.nav-tab {
  font-family: var(--mono);
  font-size: 0.78rem;
  color: var(--muted);
  padding: 0.7rem 1.1rem;
  border-bottom: 2px solid transparent;
  cursor: default;
  white-space: nowrap;
  letter-spacing: 0.03em;
}
.nav-tab.active {
  color: var(--accent2);
  border-bottom-color: var(--accent);
}

/* ── MAIN ── */
main {
  max-width: 900px;
  margin: 0 auto;
  padding: 2.5rem 2rem 4rem;
}

/* ── PAGE TITLE ── */
.page-title {
  margin-bottom: 2rem;
}
.page-title h1 {
  font-family: var(--mono);
  font-size: 1.4rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  color: var(--text);
  margin-bottom: 0.4rem;
}
.page-title p {
  font-size: 0.88rem;
  color: var(--muted);
}
.tag {
  display: inline-block;
  font-family: var(--mono);
  font-size: 0.7rem;
  background: var(--accent);
  color: #fff;
  padding: 0.15rem 0.55rem;
  border-radius: 3px;
  letter-spacing: 0.05em;
  margin-right: 0.5rem;
  vertical-align: middle;
}

/* ── TOOLS CARD ── */
.tools-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 1.4rem 1.6rem;
  margin-bottom: 2.5rem;
}
.tools-card h2 {
  font-family: var(--mono);
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  color: var(--muted);
  text-transform: uppercase;
  margin-bottom: 1rem;
}
.tools-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 0.6rem;
}
.tool-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.88rem;
  color: var(--text);
}
.tool-item::before {
  content: '→';
  color: var(--accent);
  font-family: var(--mono);
  font-size: 0.8rem;
  flex-shrink: 0;
}

/* ── HOW IT WORKS ── */
.explainer {
  background: var(--surface);
  border: 1px solid var(--border);
  border-left: 3px solid var(--accent);
  border-radius: 0 6px 6px 0;
  padding: 1.4rem 1.6rem;
  margin-bottom: 2.5rem;
}
.explainer h2 {
  font-family: var(--mono);
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  color: var(--muted);
  text-transform: uppercase;
  margin-bottom: 0.8rem;
}
.explainer p { font-size: 0.92rem; color: var(--text); }

/* ── STEPS ── */
.steps-heading {
  font-family: var(--mono);
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  color: var(--muted);
  text-transform: uppercase;
  margin-bottom: 1.2rem;
}

.step {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 0 1.5rem;
  margin-bottom: 1.6rem;
  position: relative;
}
.step:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 18px;
  top: 42px;
  bottom: -1.6rem;
  width: 1px;
  background: var(--border);
}

.step-num {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: var(--surface2);
  border: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--mono);
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--accent2);
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.step-body {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 6px;
  overflow: hidden;
}

.step-header {
  padding: 0.9rem 1.2rem;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}
.step-title {
  font-family: var(--mono);
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--text);
  letter-spacing: 0.02em;
}
.step-badge {
  font-family: var(--mono);
  font-size: 0.68rem;
  padding: 0.15rem 0.5rem;
  border-radius: 3px;
  letter-spacing: 0.04em;
  white-space: nowrap;
  flex-shrink: 0;
}
.badge-high { background: rgba(192,57,43,0.2); color: #e74c3c; border: 1px solid rgba(192,57,43,0.4); }
.badge-med  { background: rgba(211,84,0,0.2);  color: #e67e22; border: 1px solid rgba(211,84,0,0.4); }
.badge-info { background: rgba(52,152,219,0.15); color: #5dade2; border: 1px solid rgba(52,152,219,0.3); }

.step-content {
  padding: 1rem 1.2rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  align-items: start;
}
.step-content.full { grid-template-columns: 1fr; }

.step-text p {
  font-size: 0.9rem;
  color: var(--text);
  margin-bottom: 0.6rem;
}
.step-text p:last-child { margin-bottom: 0; }

.step-note {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-left: 2px solid var(--accent);
  border-radius: 0 4px 4px 0;
  padding: 0.7rem 0.9rem;
  font-size: 0.82rem;
  color: var(--muted);
  margin-top: 0.7rem;
}
.step-note strong { color: var(--text); }

.step-img {
  border-radius: 4px;
  overflow: hidden;
  background: var(--surface2);
  border: 1px solid var(--border);
  aspect-ratio: 4/3;
  display: flex;
  align-items: center;
  justify-content: center;
}
.step-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.img-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  color: var(--muted);
  font-family: var(--mono);
  font-size: 0.75rem;
  text-align: center;
  padding: 1rem;
}
.img-placeholder .icon { font-size: 1.8rem; opacity: 0.4; }

/* ── PARTS ORDER ── */
.parts-order {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  margin: 0.8rem 0;
}
.part-row {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.85rem;
}
.part-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--accent);
  flex-shrink: 0;
}
.part-name { color: var(--text); }
.part-note { color: var(--muted); font-size: 0.8rem; font-style: italic; }

/* ── WARNINGS ── */
.warnings {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 6px;
  overflow: hidden;
  margin-top: 2.5rem;
}
.warnings-header {
  background: rgba(192,57,43,0.15);
  border-bottom: 1px solid rgba(192,57,43,0.3);
  padding: 0.8rem 1.2rem;
  font-family: var(--mono);
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  color: var(--accent2);
  text-transform: uppercase;
}
.warnings-body { padding: 1.2rem; display: flex; flex-direction: column; gap: 0.8rem; }
.warn-item {
  display: flex;
  gap: 0.8rem;
  font-size: 0.88rem;
}
.warn-icon { color: var(--accent2); flex-shrink: 0; margin-top: 2px; }
.warn-text { color: var(--text); }
.warn-text strong { color: var(--accent2); }

/* ── FOOTER ── */
footer {
  border-top: 1px solid var(--border);
  padding: 1.5rem 2rem;
  text-align: center;
  font-family: var(--mono);
  font-size: 0.75rem;
  color: var(--muted);
}

/* ── RESPONSIVE ── */
@media (max-width: 640px) {
  .step-content { grid-template-columns: 1fr; }
  .step-img { display: none; }
  .tools-grid { grid-template-columns: 1fr 1fr; }
  main { padding: 1.5rem 1rem 3rem; }
  header, nav { padding: 0 1rem; }
}
